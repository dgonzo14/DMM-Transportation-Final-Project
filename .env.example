# Optional override if Airflow or LinuxLab launches outside the repo directory
MTA_REPO_ROOT=.

# ----------------------------
# MTA bronze producer
# ----------------------------
MTA_POLL_INTERVAL=30
MTA_SUBWAY_FEEDS_FILE=feeds.json
MTA_SINK_BACKEND=r2
MTA_LOCAL_BASE_PATH=./landing_zone
MTA_BRONZE_PREFIX=bronze/mta

# ----------------------------
# Cloudflare R2
# ----------------------------
R2_BUCKET=your-r2-bucket
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key

# ----------------------------
# Snowflake
# ----------------------------
SNOWFLAKE_ACCOUNT=your-snowflake-account
SNOWFLAKE_USER=your-snowflake-user
SNOWFLAKE_WAREHOUSE=your-snowflake-warehouse
SNOWFLAKE_DATABASE=your-snowflake-database
SNOWFLAKE_SCHEMA=your-snowflake-schema
SNOWFLAKE_ROLE=your-snowflake-role
SNOWFLAKE_PRIVATE_KEY_FILE=/home/your_user/.snowflake_keys/rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_FILE_PWD=

# ----------------------------
# Optional TfL settings
# ----------------------------
TFL_APP_KEY=
